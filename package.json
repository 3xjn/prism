{
	"name": "prism-v2",
	"private": true,
	"version": "0.0.0",
	"scripts": {
		"build": "rbxtsc",
		"fallow": "fallow --format human",
		"fallow:json": "fallow --format json --quiet",
		"fallow:dead-code": "fallow dead-code --format human",
		"fallow:dupes": "fallow dupes --format human",
		"fallow:health": "fallow health --score --hotspots --targets --format human",
		"fallow:audit": "fallow audit --base origin/master --format human",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"lint": "eslint src --ext .ts,.tsx",
		"format": "prettier --check ."
	},
	"dependencies": {
		"@rbxts/react": "17.3.7-ts.1",
		"@rbxts/react-roblox": "17.3.7-ts.1",
		"@rbxts/ui-labs": "2.4.2",
		"roblox-ts": "3.0.0"
	},
	"devDependencies": {
		"@rbxts/compiler-types": "3.0.0-types.0",
		"@rbxts/fusion": "0.2.0",
		"@rbxts/iris": "2.3.1-ts.1",
		"@rbxts/roact": "3.0.1",
		"@rbxts/types": "1.0.916",
		"@rbxts/vide": "0.6.1",
		"@typescript-eslint/parser": "8.58.2",
		"eslint": "8.57.1",
		"eslint-plugin-roblox-ts": "1.4.0",
		"fallow": "^2.98.0",
		"prettier": "3.8.3",
		"typescript": "5.8.3"
	}
}
